CONDA_ENV=vapi-takehome

# --- Vapi ---
VAPI_API_KEY=
VAPI_BASE_URL=https://api.vapi.ai

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Single model used for all roles if per-role vars are blank
OPENROUTER_MODEL_DEFAULT=openai/gpt-4o
# Optional: override per role
OPENROUTER_MODEL_CALLER=
OPENROUTER_MODEL_JUDGE=
OPENROUTER_MODEL_MUTATOR=

# --- Voice (disabled by default — no phone number required) ---
VOICE_ENABLED=false
# VAPI_PHONE_NUMBER_ID=
# TEST_DESTINATION_E164=

# --- Optimization hyperparameters ---
N=5
K=3
T=5
DELTA=0.03
JUDGE_VARIANCE_THRESHOLD=0.1
MAX_TURNS=12
SEED=42
