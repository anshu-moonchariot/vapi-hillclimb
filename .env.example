# Copy to .env and fill in secret values. Never commit .env.
# conda activate vapi-takehome  (see README)

CONDA_ENV=vapi-takehome

# --- Required for all CLI commands ---
# Vapi: https://dashboard.vapi.ai → API Keys
VAPI_API_KEY=
VAPI_BASE_URL=https://api.vapi.ai

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_DEFAULT=openai/gpt-4o-mini

# Optional: override model per role (leave blank to use OPENROUTER_MODEL_DEFAULT)
OPENROUTER_MODEL_CALLER=
OPENROUTER_MODEL_JUDGE=
OPENROUTER_MODEL_MUTATOR=

# --- Voice / PSTN (only when using python -m vapi_takehome.cli ... --mode voice) ---
VOICE_ENABLED=false
# VAPI_PHONE_NUMBER_ID=
# PATIENT_PHONE_NUMBER_ID=
# TEST_DESTINATION_E164=

# --- Optimization (defaults match config.py) ---
N=5
K=3
T=5
DELTA=0.03
JUDGE_VARIANCE_THRESHOLD=0.1
MAX_TURNS=12
SEED=42
